> prepare_factors <- function(dt) {
+   # AgeDiffcat: set reference level
+   if ("AgeDiffcat" %in% names(dt)) {
+     dt[, AgeDiffcat := relevel(factor(AgeDiffcat), ref = "Man 0-2yr older")]
+   }
+ 
+   # Edudiff3: set reference
+   if ("Edudiff3" %in% names(dt)) {
+     dt[, Edudiff3 := relevel(factor(Edudiff3), ref = "Different")]
+   }
+ 
+   # Bin n_years variables into 0/1/2/3+
+   for (col in c("n_years_same_uni", "n_years_same_cfar", "n_years_same_peorg")) {
+     if (col %in% names(dt)) {
+       dt[, (col) := factor(
+         fifelse(get(col) >= 3, "3+", as.character(get(col))),
+         levels = c("0", "1", "2", "3+")
+       )]
+     }
+   }
+ 
+   invisible(dt)
+ }
> 
> 
> ###############################################################################
> ####                 CORE: run_clogit_fast()                               ####
> ####     The key replacement — uses fastclogit instead of clogit           ####
> ###############################################################################
> 
> run_clogit_fast <- function(data, formula, group_var = "CoupleId",
+                              cluster_var = "LopNrEgo", use_offset = FALSE) {
+   #
+   # Takes the same inputs as the original run_clogit() but calls fastclogit.
+   #
+   # MEMORY-OPTIMIZED: builds design matrix column-by-column directly from
+   # data.table — NO model.matrix(), NO model.frame(), NO intermediate copies.
+   # This is the key difference from clogit() that saves ~60-80 GB.
+   #
+ 
+   # --- 1. Identify predictor variables from formula ---
+   formula_vars <- all.vars(formula)
+   predictor_vars <- setdiff(formula_vars, "actualpartner")
+ 
+   # Separate interaction terms from main effects
+   formula_terms <- attr(terms(formula), "term.labels")
+   interaction_terms <- formula_terms[grepl(":", formula_terms)]
+   main_terms <- formula_terms[!grepl(":", formula_terms)]
+ 
+   # Columns needed from data
+   all_vars_needed <- unique(c(
+     predictor_vars, group_var, cluster_var, "actualpartner",
+     if (use_offset) "correction"
+   ))
+   all_vars_needed <- intersect(all_vars_needed, names(data))
+ 
+   # --- 2. Drop NAs on needed columns (in-place filter via index) ---
+   complete_idx <- complete.cases(data[, ..all_vars_needed])
+   n_total <- sum(complete_idx)
+   n_dropped <- length(complete_idx) - n_total
+ 
+   if (n_dropped > 0) {
+     log_msg("    Dropped ", format(n_dropped, big.mark = ","), " rows with NAs")
+   }
+   log_msg("    Working with ", format(n_total, big.mark = ","), " rows")
+ 
+   # --- 3. Extract metadata vectors FIRST (before building X) ---
+   choice_vec  <- as.integer(data[["actualpartner"]][complete_idx])
+   strata_vec  <- data[[group_var]][complete_idx]
+   cluster_vec <- data[[cluster_var]][complete_idx]
+   offset_vec  <- if (use_offset && "correction" %in% names(data)) {
+     as.numeric(data[["correction"]][complete_idx])
+   } else {
+     NULL
+   }
+ 
+   log_memory("After extracting metadata vectors")
+ 
+   # --- 4. Build design matrix column-by-column (NO model.matrix) ---
+   # This avoids the model.frame copy that causes memory explosion.
+   # Factor columns → dummy columns; numeric columns → passed through.
+   X_cols <- list()
+   col_names <- character(0)
+ 
+   for (term in main_terms) {
+     col <- data[[term]][complete_idx]
+ 
+     if (is.factor(col) || is.character(col)) {
+       # Factor: create dummy columns (excluding reference = first level)
+       if (!is.factor(col)) col <- factor(col)
+       levs <- levels(col)
+       ref_level <- levs[1]
+       col_int <- as.integer(col)  # integer codes, 1-based
+ 
+       for (k in 2:length(levs)) {
+         dummy <- as.numeric(col_int == k)
+         X_cols[[length(X_cols) + 1]] <- dummy
+         col_names <- c(col_names, paste0(term, levs[k]))
+       }
+       rm(col, col_int, dummy)
+     } else {
+       # Numeric: pass through directly
+       X_cols[[length(X_cols) + 1]] <- as.numeric(col)
+       col_names <- c(col_names, term)
+       rm(col)
+     }
+   }
+ 
+   # Handle interaction terms (e.g., "n_years_same_cfar:ln_mean_cfar_size_c")
+   for (iterm in interaction_terms) {
+     parts <- strsplit(iterm, ":")[[1]]
+     if (length(parts) != 2) {
+       log_msg("    WARNING: skipping interaction with != 2 terms: ", iterm)
+       next
+     }
+ 
+     col1 <- data[[parts[1]]][complete_idx]
+     col2 <- data[[parts[2]]][complete_idx]
+ 
+     # Both factor: cross all non-reference levels
+     if ((is.factor(col1) || is.character(col1)) &&
+         (is.factor(col2) || is.character(col2))) {
+       if (!is.factor(col1)) col1 <- factor(col1)
+       if (!is.factor(col2)) col2 <- factor(col2)
+       int1 <- as.integer(col1)
+       int2 <- as.integer(col2)
+       for (k1 in 2:length(levels(col1))) {
+         for (k2 in 2:length(levels(col2))) {
+           X_cols[[length(X_cols) + 1]] <- as.numeric(int1 == k1 & int2 == k2)
+           col_names <- c(col_names, paste0(parts[1], levels(col1)[k1], ":",
+                                            parts[2], levels(col2)[k2]))
+         }
+       }
+     }
+     # Factor x numeric
+     else if (is.factor(col1) || is.character(col1)) {
+       if (!is.factor(col1)) col1 <- factor(col1)
+       int1 <- as.integer(col1)
+       num2 <- as.numeric(col2)
+       for (k in 2:length(levels(col1))) {
+         X_cols[[length(X_cols) + 1]] <- as.numeric(int1 == k) * num2
+         col_names <- c(col_names, paste0(parts[1], levels(col1)[k], ":", parts[2]))
+       }
+     }
+     else if (is.factor(col2) || is.character(col2)) {
+       if (!is.factor(col2)) col2 <- factor(col2)
+       int2 <- as.integer(col2)
+       num1 <- as.numeric(col1)
+       for (k in 2:length(levels(col2))) {
+         X_cols[[length(X_cols) + 1]] <- num1 * as.numeric(int2 == k)
+         col_names <- c(col_names, paste0(parts[1], ":", parts[2], levels(col2)[k]))
+       }
+     }
+     # Both numeric
+     else {
+       X_cols[[length(X_cols) + 1]] <- as.numeric(col1) * as.numeric(col2)
+       col_names <- c(col_names, iterm)
+     }
+     rm(col1, col2)
+   }
+ 
+   # Bind into matrix — single allocation
+   X <- do.call(cbind, X_cols)
+   colnames(X) <- col_names
+   rm(X_cols)
+   gc(verbose = FALSE)
+ 
+   log_msg("    Design matrix (raw): ", format(nrow(X), big.mark = ","), " x ", ncol(X),
+           " (", format(object.size(X), units = "MB"), ")")
+ 
+   # --- 4b. Drop zero-variance and collinear columns ---
+   # Track all dropped columns with reasons
+   dropped_cols <- character(0)
+   dropped_reasons <- character(0)
+ 
+   # Zero-variance check
+   col_vars <- apply(X, 2, var, na.rm = TRUE)
+   zero_var <- which(col_vars < .Machine$double.eps)
+   if (length(zero_var) > 0) {
+     log_msg("    Dropping ", length(zero_var), " zero-variance column(s): ",
+             paste(colnames(X)[zero_var], collapse = ", "))
+     dropped_cols <- c(dropped_cols, colnames(X)[zero_var])
+     dropped_reasons <- c(dropped_reasons, rep("zero variance", length(zero_var)))
+     X <- X[, -zero_var, drop = FALSE]
+   }
+ 
+   # Collinearity check via QR decomposition with column pivoting.
+   # QR pivoting selects columns greedily by largest remaining norm — columns
+   # beyond the detected rank are linear combinations of those already selected.
+   # Uses a random sample of rows (not the full 89M) to keep memory low.
+   sample_n <- min(nrow(X), 50000L)
+   sample_idx <- sort(sample.int(nrow(X), sample_n))
+   qr_check <- qr(X[sample_idx, ])
+   qr_rank <- qr_check$rank
+   if (qr_rank < ncol(X)) {
+     keep_pivot <- qr_check$pivot[seq_len(qr_rank)]
+     drop_pivot <- qr_check$pivot[(qr_rank + 1):ncol(X)]
+     dropped_qr <- colnames(X)[drop_pivot]
+     log_msg("    WARNING: rank deficiency detected (rank ", qr_rank, " < ", ncol(X), " cols)")
+     log_msg("    Dropping collinear column(s): ", paste(dropped_qr, collapse = ", "))
+     dropped_cols <- c(dropped_cols, dropped_qr)
+     dropped_reasons <- c(dropped_reasons, rep("collinear (QR pivot)", length(dropped_qr)))
+     X <- X[, keep_pivot, drop = FALSE]
+   }
+   rm(qr_check, sample_idx)
+ 
+   log_msg("    Design matrix (final): ", format(nrow(X), big.mark = ","), " x ", ncol(X),
+           " (", format(object.size(X), units = "MB"), ")")
+   log_memory("After building design matrix")
+ 
+   # --- 5. Scale continuous columns for numerical stability ---
+   # coxph (used by clogit) internally rescales columns. Without this,
+   # columns like lnDist (~9, sd ~2) vs dummies (0/1) cause the Hessian
+   # condition number to explode (rcond ~1e-18), producing singular warnings
+   # and erratic step-halving. We scale to unit sd, fit, then unscale.
+   #
+   # IMPORTANT: only scale genuinely continuous columns (sd > 1).
+   # Binary dummies have sd 0.1–0.5 — scaling those AMPLIFIES them and
+   # makes conditioning worse. We detect binary columns by checking if
+   # all values are 0 or 1.
+   col_sds <- apply(X, 2, sd)
+   # Fast binary check: sample 10K rows instead of scanning all 89M
+   sample_rows <- X[sample.int(nrow(X), min(10000L, nrow(X))), , drop = FALSE]
+   is_binary <- apply(sample_rows, 2, function(col) all(col %in% c(0, 1)))
+   rm(sample_rows)
+   needs_scaling <- !is_binary & col_sds > 1.0
+   scale_factors <- rep(1.0, ncol(X))
+   scale_factors[needs_scaling] <- col_sds[needs_scaling]
+ 
+   if (any(needs_scaling)) {
+     log_msg("    Scaling ", sum(needs_scaling), " continuous column(s): ",
+             paste(colnames(X)[needs_scaling], "(sd=",
+                   round(col_sds[needs_scaling], 2), ")", collapse = ", "))
+     X <- sweep(X, 2, scale_factors, "/")
+   } else {
+     log_msg("    No columns need scaling")
+   }
+ 
+   # --- 6. Free source data — X and vectors are all we need now ---
+   rm(data)
+   gc(verbose = FALSE)
+   log_memory("After freeing source data")
+   t_fit <- system.time({
+     fit <- tryCatch({
+       fastclogit(
+         X       = X,
+         choice  = choice_vec,
+         strata  = strata_vec,
+         offset  = offset_vec,
+         cluster = cluster_vec,
+         max_iter = 100L,
+         tol     = 1e-6,
+         verbose = CONFIG$verbose
+       )
+     }, error = function(e) {
+       log_msg("    ERROR in fastclogit: ", e$message)
+       return(NULL)
+     })
+   })
+   log_memory("After fastclogit")
+   log_msg("    Fit time: ", round(t_fit[3], 2), " seconds")
+ 
+   if (is.null(fit)) return(NULL)
+ 
+   # --- 7. Unscale coefficients and SEs back to original units ---
+   # If we fitted on X_scaled = X / s, then beta_scaled = beta_orig * s
+   # So beta_orig = beta_scaled / s, and SE_orig = SE_scaled / s
+   fit$coefficients <- fit$coefficients / scale_factors
+   fit$se           <- fit$se / scale_factors
+   fit$vcov         <- sweep(sweep(fit$vcov, 1, scale_factors, "/"), 2, scale_factors, "/")
+   if (!is.null(fit$vcov_robust)) {
+     fit$se_robust  <- fit$se_robust / scale_factors
+     fit$vcov_robust <- sweep(sweep(fit$vcov_robust, 1, scale_factors, "/"), 2, scale_factors, "/")
+   }
+   # Hessian and gradient are in scaled space — generally not used downstream,
+   # but mark them so nobody accidentally misinterprets them
+   fit$scaled <- any(needs_scaling)
+   fit$scale_factors <- scale_factors
+ 
+   # Re-apply coefficient names after unscaling.
+   # Division can strip names in some R/Rcpp edge cases, and tidy_fastclogit
+   # relies on names(object$coefficients) to build the output data.frame.
+   coef_names <- fit$terms  # set by fastclogit() — always present
+   if (is.null(coef_names)) coef_names <- colnames(X)  # fallback
+   if (!is.null(coef_names) && length(coef_names) == length(fit$coefficients)) {
+     names(fit$coefficients) <- coef_names
+     names(fit$se)           <- coef_names
+     rownames(fit$vcov) <- colnames(fit$vcov) <- coef_names
+     if (!is.null(fit$vcov_robust)) {
+       names(fit$se_robust)  <- coef_names
+       rownames(fit$vcov_robust) <- colnames(fit$vcov_robust) <- coef_names
+     }
+   }
+ 
+   # --- 8. Attach metadata, then FREE large objects ---
+   fit$n <- nrow(X)
+   fit$nevent <- sum(choice_vec)
+ 
+   # Carry dropped columns through to results
+   if (length(dropped_cols) > 0) {
+     fit$dropped_terms <- data.frame(
+       term   = dropped_cols,
+       reason = dropped_reasons,
+       stringsAsFactors = FALSE
+     )
+     log_msg("    Dropped terms attached to fit$dropped_terms")
+   } else {
+     fit$dropped_terms <- NULL
+   }
+ 
+   rm(X, choice_vec, strata_vec, cluster_vec, offset_vec, complete_idx)
+   gc(verbose = FALSE)
+   log_memory("After cleanup")
+ 
+   fit
+ }
> 
> 
> ###############################################################################
> ####              RESULT EXTRACTION: tidy_fastclogit_result()              ####
> ####     Produces the SAME output columns as tidy_clogit()                 ####
> ###############################################################################
> 
> tidy_fastclogit_result <- function(fit, model_name = "model",
+                                     exponentiate = TRUE) {
+   #
+   # Converts a fastclogit fit to data.table with columns:
+   #   model, term, estimate, std.error, conf.low, conf.high,
+   #   statistic, p.value, n_obs, n_events, loglik, concordance
+   #
+   # This matches the output of tidy_clogit() in run_clogit_models.R.
+   #
+ 
+   # Use robust SEs if available (from cluster), else model-based
+   td <- tidy_fastclogit(fit, robust = TRUE, exponentiate = FALSE)
+ 
+   coef_table <- data.table(
+     term        = td$term,
+     estimate    = td$estimate,       # log-odds
+     exp_estimate = exp(td$estimate),  # OR
+     std.error   = td$std.error,
+     statistic   = td$statistic,
+     p.value     = td$p.value,
+     conf.low    = td$conf.low,
+     conf.high   = td$conf.high
+   )
+ 
+   if (exponentiate) {
+     coef_table[, `:=`(
+       conf.low  = exp(conf.low),
+       conf.high = exp(conf.high),
+       estimate  = exp_estimate
+     )]
+   }
+ 
+   # Add model metadata (same columns as tidy_clogit)
+   coef_table[, `:=`(
+     model       = model_name,
+     n_obs       = fit$n,
+     n_events    = fit$nevent,
+     loglik      = fit$loglik,
+     concordance = NA_real_,  # fastclogit doesn't compute concordance (yet)
+     dropped     = FALSE
+   )]
+ 
+   # Append dropped columns as NA rows for transparency
+   if (!is.null(fit$dropped_terms) && nrow(fit$dropped_terms) > 0) {
+     dropped_rows <- data.table(
+       term        = fit$dropped_terms$term,
+       estimate    = NA_real_,
+       exp_estimate = NA_real_,
+       std.error   = NA_real_,
+       statistic   = NA_real_,
+       p.value     = NA_real_,
+       conf.low    = NA_real_,
+       conf.high   = NA_real_,
+       model       = model_name,
+       n_obs       = fit$n,
+       n_events    = fit$nevent,
+       loglik      = fit$loglik,
+       concordance = NA_real_,
+       dropped     = TRUE,
+       drop_reason = fit$dropped_terms$reason
+     )
+     coef_table[, drop_reason := NA_character_]
+     coef_table <- rbindlist(list(coef_table, dropped_rows), fill = TRUE)
+   }
+ 
+   setcolorder(coef_table, c("model", "term", "estimate", "std.error",
+                              "conf.low", "conf.high", "statistic", "p.value"))
+ 
+   return(coef_table)
+ }
> 
> 
> ###############################################################################
> ####              FORMAT RESULTS (identical to original)                    ####
> ###############################################################################
> 
> format_results <- function(results, digits = 3) {
+   results_fmt <- copy(results)
+   results_fmt[, estimate := round(estimate, digits)]
+   results_fmt[, std.error := round(std.error, digits)]
+   results_fmt[, conf.low := round(conf.low, digits)]
+   results_fmt[, conf.high := round(conf.high, digits)]
+   results_fmt[, CI := paste0("[", conf.low, ", ", conf.high, "]")]
+   results_fmt[, sig := fcase(
+     p.value < 0.001, "***",
+     p.value < 0.01,  "**",
+     p.value < 0.05,  "*",
+     p.value < 0.1,   ".",
+     default = ""
+   )]
+   return(results_fmt)
+ }
> 
> 
> ###############################################################################
> ####                         MAIN EXECUTION                                ####
> ###############################################################################
> 
> # Build tags
> config_tag <- build_config_tag()
> model_tag <- build_model_config_tag(CONFIG)
> model_specs <- build_model_specs(CONFIG$edu_var)
> 
> log_msg("=== fastclogit Partner Choice Models ===")
[21:57:04] === fastclogit Partner Choice Models ===
> log_msg("Tag: ", model_tag)
[21:57:04] Tag: _strat_cohort_b100_ed3_age17-45
> log_msg("Models: ", paste(CONFIG$models_to_run, collapse = ", "))
[21:57:04] Models: 4, 5
> log_msg("Education: ", CONFIG$edu_var)
[21:57:04] Education: Edudiff3
> log_msg("")
[21:57:04] 
> 
> all_results <- list()
> 
> for (sex in CONFIG$run_for_sex) {
+   log_msg("========== Sex: ", sex, " ==========")
+ 
+   # --- Determine needed columns BEFORE loading ---
+   all_model_ids <- unique(c(
+     as.character(CONFIG$models_to_run),
+     if (CONFIG$run_stratified_by_ancestry) as.character(CONFIG$stratified_models)
+   ))
+   all_formula_vars <- unique(unlist(lapply(model_specs[all_model_ids], all.vars)))
+   keep_cols <- unique(c(
+     all_formula_vars,
+     "CoupleId", "LopNrEgo", "actualpartner",
+     "correction",           # offset
+     "MacroSweEgo",          # stratified models
+     "Samelan", "AgeEgo", "Ar",  # needed for filters
+     "BothWorkplaceGeo"
+   ))
+ 
+   # --- Load ONLY needed columns from fst ---
+   data_file <- paste0("couples_cov_", sex, config_tag, CONFIG$testdata)
+   fst_path <- get_fst_path(data_file)
+   log_msg("Loading: ", data_file)
+ 
+   if (file.exists(fst_path)) {
+     # Read only the columns we need — avoids loading 117 cols (saves ~40 GB)
+     available_cols <- names(fst::fst(fst_path))
+     load_cols <- intersect(keep_cols, available_cols)
+     log_msg("  Selective load: ", length(load_cols), " of ", length(available_cols), " columns")
+     dt <- fst::read_fst(fst_path, columns = load_cols, as.data.table = TRUE)
+   } else {
+     # Fallback to full load via loaders.R
+     dt <- tryCatch({
+       load_data(data_file)
+     }, error = function(e) {
+       log_msg("ERROR loading data: ", e$message)
+       NULL
+     })
+     if (is.null(dt)) next
+     setDT(dt)
+     # Drop unneeded columns
+     drop_cols <- setdiff(names(dt), intersect(keep_cols, names(dt)))
+     if (length(drop_cols) > 0) dt[, (drop_cols) := NULL]
+   }
+ 
+   log_msg("  Loaded: ", format(nrow(dt), big.mark = ","), " rows, ",
+           ncol(dt), " columns")
+   log_memory("After load")
+ 
+   # --- Filter ---
+   n0 <- nrow(dt)
+ 
+   # Year filter
+   if ("Ar" %in% names(dt)) {
+     dt <- dt[Ar >= CONFIG$earliestyr & Ar <= CONFIG$latestyr]
+     log_msg("  Year filter [", CONFIG$earliestyr, "-", CONFIG$latestyr, "]: ",
+             format(n0 - nrow(dt), big.mark = ","), " rows removed")
+   }
+ 
+   # Age filter
+   if (!is.null(CONFIG$age_range) && "AgeEgo" %in% names(dt)) {
+     dt[, actual_age := AgeEgo[actualpartner == 1][1], by = CoupleId]
+     n_before <- nrow(dt)
+     dt <- dt[actual_age >= CONFIG$age_range[1] & actual_age <= CONFIG$age_range[2]]
+     dt[, actual_age := NULL]
+     log_msg("  Age filter [", CONFIG$age_range[1], "-", CONFIG$age_range[2], "]: ",
+             format(n_before - nrow(dt), big.mark = ","), " rows removed")
+   }
+ 
+   # Same county filter
+   if (CONFIG$samelan && !stratified_sampling && "Samelan" %in% names(dt)) {
+     n_before <- nrow(dt)
+     dt <- dt[Samelan == 1]
+     log_msg("  Same-county filter: ",
+             format(n_before - nrow(dt), big.mark = ","), " rows removed")
+   }
+ 
+   # Population restriction
+   if (CONFIG$population == "BothWorkplaceGeo" && "BothWorkplaceGeo" %in% names(dt)) {
+     keep_couples <- dt[actualpartner == 1 & BothWorkplaceGeo == 1, unique(CoupleId)]
+     n_before <- nrow(dt)
+     dt <- dt[CoupleId %in% keep_couples]
+     dt <- dt[!(actualpartner == 0 & BothWorkplaceGeo == 0)]
+     log_msg("  Workplace-geo filter: ",
+             format(n_before - nrow(dt), big.mark = ","), " rows removed")
+   }
+ 
+   # Drop filter-only columns no longer needed
+   filter_only <- c("Ar", "AgeEgo", "Samelan", "BothWorkplaceGeo")
+   filter_only <- intersect(filter_only, names(dt))
+   if (length(filter_only) > 0) dt[, (filter_only) := NULL]
+ 
+   gc(verbose = FALSE)
+   log_msg("  Final: ", format(nrow(dt), big.mark = ","), " rows, ",
+           ncol(dt), " cols, ", dt[, uniqueN(CoupleId)], " choice sets")
+   log_memory("After filters + column cleanup")
+ 
+   # --- Prepare factors ---
+   prepare_factors(dt)
+ 
+   # --- Run models ---
+   if (CONFIG$run_models) {
+     for (model_id in as.character(CONFIG$models_to_run)) {
+       log_msg("  --- Model ", model_id, " (", sex, ") ---")
+ 
+       if (!model_id %in% names(model_specs)) {
+         log_msg("    Model ", model_id, " not found in specs — skipping")
+         next
+       }
+ 
+       formula <- model_specs[[model_id]]
+       log_msg("    Formula: ", deparse(formula))
+ 
+       use_offset <- stratified_sampling && "correction" %in% names(dt)
+       if (use_offset) log_msg("    Using McFadden/Manski offset(correction)")
+ 
+       model <- run_clogit_fast(
+         data        = dt,
+         formula     = formula,
+         group_var   = "CoupleId",
+         cluster_var = "LopNrEgo",
+         use_offset  = use_offset
+       )
+ 
+       # Free dt if this is the last model AND nothing else needs it
+       # (stratified models and KHB both need dt to stay alive)
+       if (model_id == tail(as.character(CONFIG$models_to_run), 1) &&
+           !CONFIG$run_stratified_by_ancestry &&
+           !CONFIG$run_khb) {
+         log_msg("    Freeing data.table (no more models need it)")
+         rm(dt)
+         gc(verbose = FALSE)
+         log_memory("After freeing dt")
+       }
+ 
+       if (!is.null(model)) {
+         results <- tidy_fastclogit_result(
+           model,
+           model_name = paste0("model_", model_id),
+           exponentiate = CONFIG$report_odds_ratios
+         )
+         results[, sex := sex]
+         results[, model_id := model_id]
+         results[, stratified := FALSE]
+         results[, population := CONFIG$population]
+ 
+         all_results[[paste0(model_id, "_", sex)]] <- results
+ 
+         # Print summary
+         log_msg("    Converged: ", model$converged, " (", model$iterations, " iters)")
+         log_msg("    Log-lik: ", round(model$loglik, 4))
+         log_msg("    N obs: ", format(model$n, big.mark = ","))
+ 
+         if (CONFIG$save_model_objects) {
+           model_file <- paste0("model_", model_id, "_", sex, model_tag, "_fast.rds")
+           saveRDS(model, file.path(OUTPUT_PATH, model_file))
+           log_msg("    Saved: ", model_file)
+         }
+ 
+         rm(model)
+       }
+ 
+       gc(verbose = FALSE)
+     }
+   }
+ 
+   # --- Stratified by ancestry ---
+   if (CONFIG$run_models && CONFIG$run_stratified_by_ancestry &&
+       "MacroSweEgo" %in% names(dt)) {
+ 
+     macro_levels <- if (is.null(CONFIG$ancestry_groups)) {
+       dt[actualpartner == 1, unique(na.omit(MacroSweEgo))]
+     } else {
+       CONFIG$ancestry_groups
+     }
+ 
+     for (model_id in as.character(CONFIG$stratified_models)) {
+       formula <- model_specs[[model_id]]
+       use_offset <- stratified_sampling && "correction" %in% names(dt)
+ 
+       for (val in macro_levels) {
+         log_msg("  --- Model ", model_id, " stratified: MacroSweEgo = ", val, " ---")
+         dt_sub <- dt[MacroSweEgo == val]
+ 
+         if (nrow(dt_sub) < 200) {
+           log_msg("    Too few observations (", nrow(dt_sub), ") — skipping")
+           next
+         }
+ 
+         model <- run_clogit_fast(dt_sub, formula, use_offset = use_offset)
+ 
+         if (!is.null(model)) {
+           results <- tidy_fastclogit_result(
+             model,
+             model_name = paste0("model_", model_id, "_MacroSweEgo_", val),
+             exponentiate = CONFIG$report_odds_ratios
+           )
+           results[, sex := sex]
+           results[, model_id := model_id]
+           results[, stratified := TRUE]
+           results[, strat_var := "MacroSweEgo"]
+           results[, strat_value := as.character(val)]
+           results[, population := CONFIG$population]
+ 
+           all_results[[paste0(model_id, "_strat_", val, "_", sex)]] <- results
+           rm(model)
+         }
+         rm(dt_sub)
+         gc(verbose = FALSE)
+       }
+     }
+   }
+ 
+   # --- KHB mediation analysis (uses fastclogit, no survival:: needed) ---
+   if (CONFIG$run_khb) {
+     log_msg("  --- KHB mediation analysis (via fastclogit) ---")
+     log_msg("  Variable of interest: ", CONFIG$khb_variable)
+ 
+     if (!CONFIG$khb_variable %in% names(dt)) {
+       log_msg("  -> SKIPPED: Variable '", CONFIG$khb_variable, "' not found in data")
+     } else {
+ 
+       # Slim dt to only columns needed across all KHB comparisons
+       all_khb_cols <- c("actualpartner", "CoupleId", "LopNrEgo")
+       for (khb_pair in CONFIG$khb_comparisons) {
+         r_id <- khb_pair[1]; f_id <- khb_pair[2]
+         if (r_id %in% names(model_specs) && f_id %in% names(model_specs)) {
+           all_khb_cols <- c(all_khb_cols,
+                             all.vars(model_specs[[r_id]]),
+                             all.vars(model_specs[[f_id]]))
+         }
+       }
+       if (stratified_sampling) all_khb_cols <- c(all_khb_cols, "correction")
+       all_khb_cols <- unique(all_khb_cols)
+       all_khb_cols <- intersect(all_khb_cols, names(dt))
+ 
+       n_cols_before <- ncol(dt)
+       dt <- dt[, ..all_khb_cols]
+       gc(verbose = FALSE)
+       log_msg("  Slimmed dt from ", n_cols_before, " to ", ncol(dt), " columns for KHB")
+       log_memory("After dt slim for KHB")
+ 
+       khb_results_list <- list()
+ 
+       for (khb_pair in CONFIG$khb_comparisons) {
+         reduced_id <- khb_pair[1]
+         full_id <- khb_pair[2]
+         comparison_label <- paste0(reduced_id, "_to_", full_id)
+ 
+         log_msg("  KHB Comparison: Model ", reduced_id, " -> Model ", full_id)
+ 
+         # Incremental save: skip if already done in a previous (crashed) run
+         khb_comp_file <- paste0("khb_", sex, "_", comparison_label, model_tag, "_fast.csv")
+         khb_comp_path <- file.path(OUTPUT_PATH, khb_comp_file)
+         if (file.exists(khb_comp_path)) {
+           log_msg("    -> ALREADY DONE: found ", khb_comp_file)
+           cached <- fread(khb_comp_path)
+           khb_results_list[[paste0(reduced_id, "_", full_id, "_", sex)]] <- cached
+           rm(cached)
+           next
+         }
+ 
+         if (!reduced_id %in% names(model_specs) || !full_id %in% names(model_specs)) {
+           log_msg("    -> SKIPPED: Model not defined")
+           next
+         }
+ 
+         reduced_formula <- model_specs[[reduced_id]]
+         full_formula <- model_specs[[full_id]]
+         reduced_terms <- .extract_terms(reduced_formula)
+         full_terms <- .extract_terms(full_formula)
+ 
+         key_vars_khb <- if (CONFIG$khb_variable == "EduPairing_interact") {
+           c("EduAlter_3_fac",
+             "EduAlter_3_fac:EduEgoPostShort",
+             "EduAlter_3_fac:EduEgoPostLong")
+         } else {
+           CONFIG$khb_variable
+         }
+         concomitant_khb <- setdiff(reduced_terms, key_vars_khb)
+         z_vars_khb <- setdiff(full_terms, reduced_terms)
+ 
+         log_msg("    Key variable (X):   ", paste(key_vars_khb, collapse = ", "))
+         log_msg("    Mediators (Z):      ", paste(z_vars_khb, collapse = ", "))
+         log_msg("    Concomitants (C):   ", paste(concomitant_khb, collapse = ", "))
+ 
+         if (length(z_vars_khb) == 0) {
+           log_msg("    -> SKIPPED: No new variables in full model")
+           next
+         }
+ 
+         # Pre-filter columns for this comparison
+         khb_needed_cols <- unique(c(
+           "actualpartner", "CoupleId", "LopNrEgo",
+           all.vars(reduced_formula), all.vars(full_formula)))
+         if (stratified_sampling) khb_needed_cols <- unique(c(khb_needed_cols, "correction"))
+         khb_needed_cols <- intersect(khb_needed_cols, names(dt))
+         dt_khb <- dt[, ..khb_needed_cols]
+ 
+         # Run KHB decomposition (via fastclogit)
+         khb_result <- tryCatch({
+           khb_clogit(
+             data = dt_khb,
+             key_vars = key_vars_khb,
+             z_vars = z_vars_khb,
+             concomitant = concomitant_khb,
+             group_var = "CoupleId",
+             cluster_var = "LopNrEgo",
+             use_offset = stratified_sampling
+           )
+         }, error = function(e) {
+           log_msg("    -> ERROR: ", e$message)
+           return(NULL)
+         })
+         rm(dt_khb)
+         gc(verbose = FALSE)
+         log_memory(paste0("After KHB comparison ", reduced_id, "-", full_id))
+ 
+         if (!is.null(khb_result) && khb_result$success) {
+           decomp <- khb_result$decomposition
+           log_msg("    -> SUCCESS")
+ 
+           for (i in 1:nrow(decomp)) {
+             r <- decomp[i]
+             log_msg("       ", r$coefficient, ":")
+             log_msg("         Total:    ", round(r$total_effect, 4))
+             log_msg("         Direct:   ", round(r$direct_effect, 4))
+             log_msg("         Indirect: ", round(r$indirect_effect, 4))
+             log_msg("         % Mediated: ", round(r$conf_pct, 1), "%")
+           }
+ 
+           decomp_out <- copy(decomp)
+           decomp_out[, `:=`(sex = sex, comparison = comparison_label,
+                              population = CONFIG$population)]
+           khb_results_list[[paste0(reduced_id, "_", full_id, "_", sex)]] <- decomp_out
+ 
+           # Incremental save
+           fwrite(decomp_out, khb_comp_path)
+           log_msg("    Saved: ", khb_comp_file)
+           rm(khb_result, decomp, decomp_out)
+           gc(verbose = FALSE)
+ 
+         } else if (!is.null(khb_result)) {
+           log_msg("    -> FAILED: ", khb_result$error)
+           rm(khb_result)
+           gc(verbose = FALSE)
+         } else {
+           log_msg("    -> FAILED: khb_clogit returned NULL (see error above)")
+         }
+       }
+ 
+       if (length(khb_results_list) > 0) {
+         khb_combined <- rbindlist(khb_results_list, fill = TRUE)
+         all_results[[paste0("khb_", sex)]] <- khb_combined
+ 
+         khb_file <- paste0("khb_results_", sex, model_tag, "_fast.csv")
+         fwrite(khb_combined, file.path(OUTPUT_PATH, khb_file))
+         log_msg("  Saved combined: ", khb_file)
+       }
+     }
+     log_memory("After KHB analysis")
+   }
+ 
+   if (exists("dt")) rm(dt)
+   gc(verbose = FALSE)
+ }
