> build_model_specs <- function(edu_var) {
+   # Education terms
+   edu_terms <- if (edu_var == "EduPairing_interact") {
+     c("EduAlter_3_fac",
+       "EduAlter_3_fac:EduEgoPostShort",
+       "EduAlter_3_fac:EduEgoPostLong")
+   } else {
+     edu_var
+   }
+ 
+   # Base controls (same across all models)
+   controls <- c("AgeDiffcat", "SameMicroAnc", "MesoNotMicro",
+                 "AlterFirstGen", "BothFirstGen")
+ 
+   f <- function(...) {
+     terms <- c(edu_terms, controls, ...)
+     as.formula(paste("actualpartner ~", paste(terms, collapse = " + ")))
+   }
+ 
+   list(
+     "0" = f(),
+     "1" = f("n_years_same_uni"),
+     "2" = f("n_years_same_uni", "n_years_same_cfar"),
+     "3" = f("n_years_same_uni", "n_years_same_cfar", "n_years_same_peorg"),
+     "4" = f("n_years_same_uni", "n_years_same_cfar", "n_years_same_peorg", "lnDist"),
+     "5" = f("n_years_same_uni",
+             "n_years_same_cfar", "ln_mean_cfar_size_c", "n_years_same_cfar:ln_mean_cfar_size_c",
+             "n_years_same_peorg", "ln_mean_peorg_size_c", "n_years_same_peorg:ln_mean_peorg_size_c",
+             "lnDist")
+   )
+ }
